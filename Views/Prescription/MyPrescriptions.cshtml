@model IEnumerable<PracticeFlow.Models.Prescription>

@{
    ViewData["Title"] = "My Prescriptions";
}

<div class="container mt-4">
    <h2>My Prescriptions</h2>
    <hr />

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <p>You have no prescriptions on record.</p>
        </div>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Medication</th>
                    <th>Dosage</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Instructions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var prescription in Model)
                {
                    <tr>
                        <td>@prescription.MedicationName</td>
                        <td>@prescription.Dosage</td>
                        <td>@prescription.StartDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (prescription.EndDate.HasValue)
                            {
                                @prescription.EndDate.Value.ToString("yyyy-MM-dd")
                            }
                            else
                            {
                                <span class="text-muted">Ongoing</span>
                            }
                        </td>
                        <td>@prescription.Instructions</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="mt-3">
        <a asp-controller="Home" asp-action="PatientDashboard" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>