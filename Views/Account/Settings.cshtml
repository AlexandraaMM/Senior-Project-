@model PracticeFlow.Models.User

@{
    ViewData["Title"] = "Account Settings";
}

<div class="container mt-4">
    <h2>Account Settings</h2>
    <hr />

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <!-- Update Name -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Update Name</h5>
                </div>
                <div class="card-body">
                    <form asp-action="UpdateName" method="post">
                        <div class="mb-3">
                            <label class="form-label">Full Name</label>
                            <input type="text" name="FullName" class="form-control" value="@Model.FullName" required />
                        </div>
                        <button type="submit" class="btn btn-primary">Update Name</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Change Password -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header bg-warning">
                    <h5 class="mb-0">Change Password</h5>
                </div>
                <div class="card-body">
                    <p>Update your account password for security.</p>
                    <a asp-action="ChangeMyPassword" class="btn btn-warning">Change Password</a>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>