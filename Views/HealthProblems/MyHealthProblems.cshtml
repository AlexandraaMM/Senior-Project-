@model IEnumerable<PracticeFlow.Models.HealthProblem>
@{
    ViewData["Title"] = "My Health Problems";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>My Health Problems</h2>
    <a asp-controller="Home" asp-action="PatientDashboard" 
       class="btn btn-secondary">Back to Dashboard</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No health problems have been recorded for you yet.
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Problem</th>
                <th>Diagnosed</th>
                <th>Status</th>
                <th>Resolved</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var problem in Model)
            {
                <tr>
                    <td>@problem.ProblemDescription</td>
                    <td>@problem.DiagnosedDate.ToString("MMM dd, yyyy")</td>
                    <td>
                        @if (problem.Status == "Active")
                        {
                            <span class="badge bg-warning text-dark">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Resolved</span>
                        }
                    </td>
                    <td>@(problem.ResolvedDate?.ToString("MMM dd, yyyy") ?? "—")</td>
                    <td>
                        <a asp-action="MyGoals" asp-route-problemId="@problem.ProblemID"
                           class="btn btn-sm"
                           style="background-color: #06b6d4; border-color: #06b6d4; color: white;">
                            View Goals
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}