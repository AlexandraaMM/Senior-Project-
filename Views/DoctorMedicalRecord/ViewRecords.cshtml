@model IEnumerable<PracticeFlow.Models.MedicalRecord>

@{
    ViewData["Title"] = "Medical Records";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Medical Records</h2>
    <a asp-controller="Home" asp-action="DoctorDashboard" class="btn btn-secondary">Back to Dashboard</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No medical records found.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Date</th>
                <th>Patient</th>
                <th>Reason for Visit</th>
                <th>Diagnosis</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var record in Model)
            {
                <tr>
                    <td>@record.RecordDate.ToString("MMM dd, yyyy")</td>
                    <td>@record.Patient!.FullName</td>
                    <td>@record.ReasonForVisit</td>
                    <td>@record.Diagnosis</td>
                    <td>
                        <a asp-action="ViewDetails" asp-route-id="@record.RecordId" class="btn btn-sm" style="background-color: #06b6d4; border-color: #06b6d4; color: white;">
                            View Details
                        </a>
                        <a asp-controller="Prescription" asp-action="Create" asp-route-recordId="@record.RecordId" class="btn btn-sm" style="background-color: #10b981; border-color: #10b981; color: white;">
                            Add Prescription
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}