@model IEnumerable<PracticeFlow.Models.MedicalRecord>

@{
    ViewData["Title"] = "Medical Records";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Medical Records</h2>
        <a asp-controller="Home" asp-action="DoctorDashboard" class="btn btn-secondary">Back to Dashboard</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No medical records found. Records will appear here once you complete appointments and record visit notes.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Date</th>
                        <th>Patient</th>
                        <th>Reason for Visit</th>
                        <th>Diagnosis</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var record in Model)
                    {
                        <tr>
                            <td>@record.RecordDate.ToString("MMM dd, yyyy")</td>
                            <td>@record.Patient?.FullName</td>
                            <td>@record.ReasonForVisit</td>
                            <td>@record.Diagnosis</td>
                            <td>
                                <a href="#" class="btn btn-sm btn-primary">View Details</a>
                                <a href="#" class="btn btn-sm btn-success">Add Prescription</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <div class="mt-3">
            <p class="text-muted">Total Records: @Model.Count()</p>
        </div>
    }
</div>