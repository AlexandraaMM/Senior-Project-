@model IEnumerable<PracticeFlow.Models.MedicalRecord>

@{
    ViewData["Title"] = "Patient Medical History";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Medical History - @ViewBag.PatientName</h2>
    <a asp-controller="DoctorPatient" asp-action="ViewPatients" class="btn btn-secondary">Back to Patients</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No medical records found for this patient.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Date</th>
                <th>Reason for Visit</th>
                <th>Diagnosis</th>
                <th>Treatment</th>
                <th>Prescriptions</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var record in Model)
            {
                <tr>
                    <td>@record.RecordDate.ToString("MMM dd, yyyy")</td>
                    <td>@record.ReasonForVisit</td>
                    <td>@record.Diagnosis</td>
                    <td>@record.Treatment</td>
                    <td>
                        @if (record.Prescriptions != null && record.Prescriptions.Any())
                        {
                            <span class="badge bg-success">@record.Prescriptions.Count</span>
                        }
                        else
                        {
                            <span class="text-muted">None</span>
                        }
                    </td>
                    <td>
                        <a asp-action="ViewDetails" asp-route-id="@record.RecordId" 
                           class="btn btn-sm" style="background-color: #06b6d4; border-color: #06b6d4; color: white;">
                            View Details
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}