@model PracticeFlow.Models.Prescription

@{
    ViewData["Title"] = "Add Prescription";
}

<div class="container mt-4">
    <h2>Add Prescription - @ViewBag.PatientName</h2>
    <hr />

    <form method="post" asp-action="AddPrescription">
        @Html.AntiForgeryToken()
        <input type="hidden" name="RecordId" value="@ViewBag.RecordId" />
        <input type="hidden" name="PatientID" value="@ViewBag.PatientID" />

        <div class="form-group mb-3">
            <label>Medication Name *</label>
            <input name="MedicationName" class="form-control" required />
        </div>

        <div class="form-group mb-3">
            <label>Dosage *</label>
            <input name="Dosage" class="form-control" placeholder="e.g., 500mg twice daily" required />
        </div>

        <div class="form-group mb-3">
            <label>Start Date *</label>
            <input name="StartDate" type="date" class="form-control" required />
        </div>

        <div class="form-group mb-3">
            <label>End Date</label>
            <input name="EndDate" type="date" class="form-control" />
        </div>

        <div class="form-group mb-3">
            <label>Instructions</label>
            <textarea name="Instructions" class="form-control" rows="3" placeholder="Special instructions for the patient"></textarea>
        </div>

        <div class="form-group">
            <button type="submit" class="btn btn-primary">Add Prescription</button>
            <a asp-action="ViewRecords" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>