@model PracticeFlow.Models.MedicalRecord

@{
    ViewData["Title"] = "Medical Record Details";
}

<div class="container mt-4">
    <h2>Medical Record Details</h2>
    <hr />

    <div class="card">
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-3"><strong>Patient:</strong></div>
                <div class="col-md-9">@Model.Patient.FullName</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><strong>Doctor:</strong></div>
                <div class="col-md-9">@Model.Doctor.FullName</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><strong>Date:</strong></div>
                <div class="col-md-9">@Model.RecordDate.ToString("MMMM dd, yyyy")</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><strong>Reason for Visit:</strong></div>
                <div class="col-md-9">@Model.ReasonForVisit</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><strong>Diagnosis:</strong></div>
                <div class="col-md-9">@Model.Diagnosis</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><strong>Treatment:</strong></div>
                <div class="col-md-9">@Model.Treatment</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><strong>Prescription:</strong></div>
                <div class="col-md-9">@Model.Prescription</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><strong>Notes:</strong></div>
                <div class="col-md-9">@Model.Notes</div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="AddPrescription" asp-route-id="@Model.RecordId" class="btn btn-success">Add Prescription</a>
        <a asp-action="ViewRecords" class="btn btn-secondary">Back to Records</a>
    </div>
</div>