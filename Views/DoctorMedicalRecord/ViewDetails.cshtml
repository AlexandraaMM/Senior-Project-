@model PracticeFlow.Models.MedicalRecord

@{
    ViewData["Title"] = "Medical Record Details";
}

<div class="container mt-4">
    <h2>Medical Record Details</h2>
    <hr />

    <div class="card">
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-3"><strong>Patient:</strong></div>
                <div class="col-md-9">@Model.Patient!.FullName</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><strong>Doctor:</strong></div>
                <div class="col-md-9">@Model.Doctor!.FullName</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><strong>Date:</strong></div>
                <div class="col-md-9">@Model.RecordDate.ToString("MMMM dd, yyyy")</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><strong>Reason for Visit:</strong></div>
                <div class="col-md-9">@Model.ReasonForVisit</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><strong>Diagnosis:</strong></div>
                <div class="col-md-9">@Model.Diagnosis</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><strong>Treatment:</strong></div>
                <div class="col-md-9">@Model.Treatment</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><strong>Prescription:</strong></div>
                <div class="col-md-9">@Model.Prescription</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><strong>Notes:</strong></div>
                <div class="col-md-9">@Model.Notes</div>
            </div>
        </div>
    </div>

    <hr />
    <h4>Prescriptions for this Visit</h4>

    @if (ViewBag.Prescriptions != null && ((List<PracticeFlow.Models.Prescription>)ViewBag.Prescriptions).Any())
    {
        <table class="table table-bordered">
            <thead class="table-light">
                <tr>
                    <th>Medication</th>
                    <th>Dosage</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Instructions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var prescription in (List<PracticeFlow.Models.Prescription>)ViewBag.Prescriptions)
                {
                    <tr>
                        <td>@prescription.MedicationName</td>
                        <td>@prescription.Dosage</td>
                        <td>@prescription.StartDate.ToString("MMM dd, yyyy")</td>
                        <td>@(prescription.EndDate?.ToString("MMM dd, yyyy") ?? "Ongoing")</td>
                        <td>@prescription.Instructions</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">No prescriptions added for this visit yet.</p>
    }

    <hr />
    <h4>Patient Vitals History</h4>

    @if (ViewBag.VitalsHistory != null && ((List<PracticeFlow.Models.VitalsLog>)ViewBag.VitalsHistory).Any())
    {
        <table class="table table-bordered">
            <thead class="table-light">
                <tr>
                    <th>Date</th>
                    <th>Weight (kg)</th>
                    <th>Height (cm)</th>
                    <th>BMI</th>
                    <th>Category</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var vital in (List<PracticeFlow.Models.VitalsLog>)ViewBag.VitalsHistory)
                {
                    var bmi = vital.BMI ?? 0;
                    var category = vital.BMICategory;
                    var badgeColor = bmi < 18.5m ? "warning" : 
                                     bmi < 25m ? "success" : 
                                     bmi < 30m ? "warning" : "danger";
                    
                    <tr>
                        <td>@vital.RecordedDate.ToString("MMM dd, yyyy")</td>
                        <td>@vital.Weight_kg</td>
                        <td>@vital.Height_cm</td>
                        <td>@(vital.BMI?.ToString("F1") ?? "N/A")</td>
                        <td><span class="badge bg-@badgeColor">@category</span></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">No vitals recorded for this patient yet.</p>
    }

    <div class="mt-3">
        <a asp-action="AddPrescription" asp-route-id="@Model.RecordId" class="btn btn-success">Add Prescription</a>
        <a asp-action="ViewRecords" class="btn btn-secondary">Back to Records</a>
    </div>
</div>