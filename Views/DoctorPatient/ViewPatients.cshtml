@model IEnumerable<PracticeFlow.Models.User>

@{
    ViewData["Title"] = "My Patients";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>My Patients</h2>
        <a asp-controller="Home" asp-action="DoctorDashboard" class="btn btn-secondary">Back to Dashboard</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            You don't have any patients yet. Patients will appear here once they book appointments with you.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Patient Name</th>
                        <th>Email</th>
                        <th>Date of Birth</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var patient in Model)
                    {
                        <tr>
                            <td>@patient.FullName</td>
                            <td>@patient.Email</td>
                            <td>@(patient.DateOfBirth?.ToString("MMM dd, yyyy") ?? "N/A")</td>
                            <td>
                                
                                <a asp-action="ViewDetails" asp-route-id="@patient.UserID" class="btn btn-sm btn-primary">View Details</a>
                                <a asp-action="MedicalHistory" asp-route-id="@patient.UserID" class="btn btn-sm btn-info">Medical History</a>
                                <a asp-action="LogVitals" asp-route-id="@patient.UserID" class="btn btn-sm btn-success">Log Vitals</a>
                                
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <div class="mt-3">
            <p class="text-muted">Total Patients: @Model.Count()</p>
        </div>
    }
</div>