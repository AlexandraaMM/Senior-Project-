@model IEnumerable<PracticeFlow.Models.User>

@{
    ViewData["Title"] = "My Patients";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>My Patients</h2>
    <a asp-controller="Home" asp-action="DoctorDashboard" class="btn btn-secondary">Back to Dashboard</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No patients found.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Patient Name</th>
                <th>Email</th>
                <th>Date of Birth</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var patient in Model)
            {
                <tr>
                    <td>@patient.FullName</td>
                    <td>@patient.Email</td>
                    <td>
                        @if (patient.DateOfBirth.HasValue)
                        {
                            @patient.DateOfBirth.Value.ToString("MMM dd, yyyy")
                        }
                        else
                        {
                            <span class="text-muted">N/A</span>
                        }
                    </td>
                    <td>
                        <a asp-action="ViewDetails" asp-route-id="@patient.UserID" 
                        class="btn btn-sm" 
                        style="background-color: #8b5cf6; border-color: #8b5cf6; color: white;">
                        View Details
                        </a>
                        <a asp-controller="DoctorMedicalRecord" asp-action="PatientHistory" asp-route-patientId="@patient.UserID" 
                        class="btn btn-sm" 
                        style="background-color: #06b6d4; border-color: #06b6d4; color: white;">
                        Medical History
                        </a>
                        <a asp-controller="VitalsLog" asp-action="Create" asp-route-patientId="@patient.UserID" 
                        class="btn btn-sm" 
                        style="background-color: #10b981; border-color: #10b981; color: white;">
                        Log Vitals
                        </a>
                        <a asp-controller="HealthProblems" asp-action="Index"
                        asp-route-patientId="@patient.UserID"
                        class="btn btn-sm"
                        style="background-color: #f59e0b; border-color: #f59e0b; color: white;">
                        Health Problems
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <p class="text-muted mt-3">Total Patients: @Model.Count()</p>
}