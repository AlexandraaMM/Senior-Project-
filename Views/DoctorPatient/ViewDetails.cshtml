@model PracticeFlow.Models.User

@{
    ViewData["Title"] = "Patient Details";
}

<div class="container mt-4">
    <h2>Patient Details</h2>
    <hr />

    <div class="card">
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-3"><strong>Full Name:</strong></div>
                <div class="col-md-9">@Model.FullName</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><strong>Username:</strong></div>
                <div class="col-md-9">@Model.Username</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><strong>Email:</strong></div>
                <div class="col-md-9">@Model.Email</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><strong>Date of Birth:</strong></div>
                <div class="col-md-9">
                    @if (Model.DateOfBirth.HasValue)
                    {
                        @Model.DateOfBirth.Value.ToString("MMMM dd, yyyy")
                    }
                    else
                    {
                        <span class="text-muted">Not provided</span>
                    }
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><strong>Patient ID:</strong></div>
                <div class="col-md-9">@Model.UserID</div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-controller="DoctorMedicalRecord" asp-action="PatientHistory" asp-route-patientId="@Model.UserID" 
           class="btn" style="background-color: #06b6d4; border-color: #06b6d4; color: white;">
            View Medical History
        </a>
        <a asp-controller="VitalsLog" asp-action="Index" asp-route-patientId="@Model.UserID" 
           class="btn" style="background-color: #10b981; border-color: #10b981; color: white;">
            View Vitals History
        </a>
        <a asp-controller="DoctorPatient" asp-action="ViewPatients" class="btn btn-secondary">
            Back to Patients
        </a>
        <a asp-controller="HealthProblems" asp-action="Index"
            asp-route-patientId="@Model.UserID"
            class="btn"
            style="background-color: #8b5cf6; border-color: #8b5cf6; color: white;">
                Health Problems
        </a>
    </div>
</div>