@model PracticeFlow.Models.VitalsLog

@{
    ViewData["Title"] = "Log Vitals";
}

<div class="container mt-4">
    <h2>Log Vitals - @ViewBag.PatientName</h2>
    <hr />

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <form method="post" asp-action="LogVitals">
        @Html.AntiForgeryToken()
        
        <input type="hidden" name="PatientID" value="@ViewBag.PatientID" />

        <div class="form-group mb-3">
            <label>Weight (kg) *</label>
            <input name="Weight_kg" type="number" step="0.1" class="form-control" 
                   placeholder="e.g., 70.5" required />
            <span asp-validation-for="Weight_kg" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label>Height (cm) *</label>
            <input name="Height_cm" type="number" step="0.1" class="form-control" 
                   placeholder="e.g., 175" required />
            <span asp-validation-for="Height_cm" class="text-danger"></span>
        </div>

        <div class="alert alert-info">
            <strong>📊 Note:</strong> BMI will be calculated automatically.
        </div>

        <div class="form-group">
            <button type="submit" class="btn btn-primary">Record Vitals</button>
            <a asp-action="ViewPatients" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}