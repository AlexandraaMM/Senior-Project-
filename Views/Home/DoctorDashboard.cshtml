@{
    ViewData["Title"] = "Doctor Dashboard";
}

<!-- Welcome Banner with Gradient -->
<div class="container-fluid px-0">
    <div class="p-4 mb-4 text-white" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 0 0 20px 20px;">
        <div class="container">
            <h1 class="display-5 fw-bold mb-2">
                <i class="bi bi-heart-pulse-fill"></i> Welcome, Dr. @ViewBag.FullName!
            </h1>
            <p class="lead mb-0">Manage your patients and medical practice</p>
        </div>
    </div>
</div>

<div class="container mt-4">
    <div class="row g-4">
        <!-- Appointments Card -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100" style="transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="me-3">
                            <i class="bi bi-calendar-event" style="font-size: 2.2rem; color: #667eea;"></i>
                        </div>
                        <div>
                            <h4 class="mb-1">Appointments</h4>
                            <p class="text-muted mb-0">View scheduled appointments</p>
                        </div>
                    </div>
                    <div class="d-grid">
                        <a asp-controller="Appointment" asp-action="DoctorAppointments" class="btn" style="background-color: #667eea; border-color: #667eea; color: white;">
                            <i class="bi bi-calendar-check"></i> View Schedule
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Medical Records Card -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100" style="transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="me-3">
                            <i class="bi bi-clipboard2-pulse" style="font-size: 2.2rem; color: #06b6d4;"></i>
                        </div>
                        <div>
                            <h4 class="mb-1">Medical Records</h4>
                            <p class="text-muted mb-0">Access patient medical records</p>
                        </div>
                    </div>
                    <div class="d-grid">
                        <a asp-controller="DoctorMedicalRecord" asp-action="ViewRecords" class="btn" style="background-color: #06b6d4; border-color: #06b6d4; color: white;">
                            <i class="bi bi-folder2-open"></i> View Records
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- My Patients Card -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100" style="transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="me-3">
                            <i class="bi bi-people" style="font-size: 2.2rem; color: #8b5cf6;"></i>
                        </div>
                        <div>
                            <h4 class="mb-1">My Patients</h4>
                            <p class="text-muted mb-0">View and manage your patients</p>
                        </div>
                    </div>
                    <div class="d-grid">
                        <a asp-controller="DoctorPatient" asp-action="ViewPatients" class="btn" style="background-color: #8b5cf6; border-color: #8b5cf6; color: white;">
                            <i class="bi bi-person-lines-fill"></i> View Patients
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Record Medical Visit Card -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100" style="transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="me-3">
                            <i class="bi bi-journal-medical" style="font-size: 2.2rem; color: #f59e0b;"></i>
                        </div>
                        <div>
                            <h4 class="mb-1">Record Medical Visit</h4>
                            <p class="text-muted mb-0">Document patient encounters</p>
                        </div>
                    </div>
                    <div class="d-grid">
                        <a asp-controller="MedicalRecord" asp-action="Create" class="btn" style="background-color: #f59e0b; border-color: #f59e0b; color: white;">
                            <i class="bi bi-pencil-square"></i> Create Record
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card:hover {
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
</style>