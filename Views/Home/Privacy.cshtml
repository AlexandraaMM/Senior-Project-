@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container mt-4">
    <h1>Privacy Policy</h1>
    <p class="text-muted">Your privacy and data security matter to us</p>
    <hr />

    <h3>What Information We Collect</h3>
    <p>When you use Process Health, we collect:</p>
    <ul>
        <li><strong>Account Information:</strong> Your name, email address, date of birth, and login credentials</li>
        <li><strong>Medical Information:</strong> Health records, diagnoses, prescriptions, vital signs, and appointment history</li>
        <li><strong>Usage Information:</strong> When you login and which features you use</li>
    </ul>

    <h3>How We Use Your Information</h3>
    <p>We use your information to:</p>
    <ul>
        <li>Provide medical care and manage your appointments</li>
        <li>Keep accurate medical records</li>
        <li>Allow your doctor to access your health information</li>
    </ul>

    <h3>Who Can See Your Information</h3>
    <p><strong>Patients:</strong> You can only see your own medical records and appointments.</p>
    <p><strong>Doctors:</strong> Can see medical information for their assigned patients only.</p>
    <p><strong>Administrators:</strong> Can manage user accounts, but cannot access medical records.</p>
    <p class="alert alert-warning">
        <strong>Important:</strong> We never share your medical information with third parties without your permission.
    </p>

    <h3>How We Protect Your Data</h3>
    <ul>
        <li>All passwords are encrypted and cannot be read by anyone, including administrators</li>
        <li>You must log in to access the system</li>
        <li>Only authorized users can see medical information</li>
    </ul>

    <h3>Your Rights</h3>
    <p>You have the right to:</p>
    <ul>
        <li><strong>Access:</strong> View all your personal and medical information</li>
        <li><strong>Update:</strong> Change your name and password anytime through Settings</li>
        <li><strong>Delete:</strong> Request account deletion (contact an administrator)</li>
    </ul>

    <h3>Questions?</h3>
    <p>
        If you have questions about your privacy or how we handle your information, 
        please contact your healthcare provider or system administrator.
    </p>
</div>

