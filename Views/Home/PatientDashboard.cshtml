@{
    ViewData["Title"] = "Patient Dashboard";
}

<!-- Welcome Banner with Gradient -->
<div class="container-fluid px-0">
    <div class="p-4 mb-4 text-white" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 0 0 20px 20px;">
        <div class="container">
            <h1 class="display-5 fw-bold mb-2">
                <i class="bi bi-heart-pulse-fill"></i> Welcome, @ViewBag.FullName!
            </h1>
            <p class="lead mb-0">Manage your health appointments and records</p>
        </div>
    </div>
</div>

<div class="container mt-4">
    <!-- Statistics Cards Row -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #667eea !important; transition: transform 0.2s;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Upcoming</h6>
                            <h3 class="fw-bold mb-0" style="color: #667eea;">
                                @(ViewBag.UpcomingCount ?? 0)
                            </h3>
                            <small class="text-muted">Appointments</small>
                        </div>
                        <div>
                            <i class="bi bi-calendar-check" style="font-size: 2.5rem; color: #667eea;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #06b6d4 !important; transition: transform 0.2s;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Recent</h6>
                            <h3 class="fw-bold mb-0" style="color: #06b6d4;">
                                @(ViewBag.RecordsCount ?? 0)
                            </h3>
                            <small class="text-muted">Medical Records</small>
                        </div>
                        <div>
                            <i class="bi bi-file-medical" style="font-size: 2.5rem; color: #06b6d4;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #10b981 !important; transition: transform 0.2s;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Active</h6>
                            <h3 class="fw-bold mb-0" style="color: #10b981;">
                                @(ViewBag.PrescriptionsCount ?? 0)
                            </h3>
                            <small class="text-muted">Prescriptions</small>
                        </div>
                        <div>
                            <i class="bi bi-capsule" style="font-size: 2.5rem; color: #10b981;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Appointments Card -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100" style="transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="me-3">
                            <i class="bi bi-calendar-event" style="font-size: 2.2rem; color: #667eea;"></i>
                        </div>
                        <div>
                            <h4 class="mb-1">Appointments</h4>
                            <p class="text-muted mb-0">View and manage your appointments</p>
                        </div>
                    </div>
                    <div class="d-grid gap-2">
                        <a asp-controller="Appointment" asp-action="MyAppointments" class="btn" style="background-color: transparent; border: 2px solid #667eea; color: #667eea;">
                            <i class="bi bi-eye"></i> View All Appointments
                        </a>
                        <a asp-controller="Appointment" asp-action="Book" class="btn" style="background-color: #667eea; border-color: #667eea; color: white;">
                            <i class="bi bi-plus-circle"></i> Book New Appointment
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Medical Records Card -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100" style="transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="me-3">
                            <i class="bi bi-clipboard2-pulse" style="font-size: 2.2rem; color: #06b6d4;"></i>
                        </div>
                        <div>
                            <h4 class="mb-1">Medical Records</h4>
                            <p class="text-muted mb-0">Access your health history</p>
                        </div>
                    </div>
                    <div class="d-grid">
                        <a asp-controller="MedicalRecord" asp-action="MyRecords" class="btn" style="background-color: #06b6d4; border-color: #06b6d4; color: white;">
                            <i class="bi bi-folder2-open"></i> View Medical Records
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Health Problems Card -->
        <div class="col-lg-12">
            <div class="card border-0 shadow-sm" 
                style="transition: transform 0.2s;" 
                onmouseover="this.style.transform='translateY(-5px)'" 
                onmouseout="this.style.transform='translateY(0)'">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="me-3">
                            <i class="bi bi-heart-pulse" 
                            style="font-size: 2.2rem; color: #f59e0b;"></i>
                        </div>
                        <div>
                            <h4 class="mb-1">My Health Problems</h4>
                            <p class="text-muted mb-0">
                                View your chronic conditions and treatment goals
                            </p>
                        </div>
                    </div>
                    <div class="d-grid">
                        <a asp-controller="HealthProblems" asp-action="MyHealthProblems" 
                        class="btn" 
                        style="background-color: #f59e0b; border-color: #f59e0b; color: white;">
                            <i class="bi bi-clipboard2-heart"></i> View Health Problems
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Prescriptions Card -->
        <div class="col-lg-12">
            <div class="card border-0 shadow-sm" style="transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="me-3">
                            <i class="bi bi-prescription2" style="font-size: 2.2rem; color: #10b981;"></i>
                        </div>
                        <div>
                            <h4 class="mb-1">My Prescriptions</h4>
                            <p class="text-muted mb-0">View your active medications and prescriptions</p>
                        </div>
                    </div>
                    <div class="d-grid">
                        <a asp-controller="Prescription" asp-action="MyPrescriptions" class="btn" style="background-color: #10b981; border-color: #10b981; color: white;">
                            <i class="bi bi-capsule-pill"></i> View Prescriptions
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card:hover {
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
</style>