@model PracticeFlow.Models.User

@{
    ViewData["Title"] = "Patient Dashboard";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Welcome @Model.FullName!</h1>
        <a asp-controller="Account" asp-action="Logout" class="btn btn-danger">Logout</a>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h3>Upcoming Appointments</h3>
                </div>
                <div class="card-body">
                    <a href="/Appointment/MyAppointments" class="btn btn-primary">View All</a>
                    <a href="/Appointment/Book" class="btn btn-success">Book New</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h3>Recent Medical Records</h3>
                </div>
                <div class="card-body">
                    <a href="/MedicalRecord/MyRecords" class="btn btn-primary">View Records</a>
                </div>
            </div>
        </div>
    </div>
</div>