@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Welcome @ViewBag.FullName!</h1>
        <a asp-controller="Account" asp-action="Logout" class="btn btn-danger">Logout</a>
    </div>
    
    <div class="row">
        <div class="col-md-4">
            <div class="card text-white bg-primary mb-3">
                <div class="card-body">
                    <h5 class="card-title">Manage Users</h5>
                    <p class="card-text">View and manage all system users</p>
                    <a asp-controller="Admin" asp-action="ViewUsers" class="btn btn-light">Go to Users</a>
                </div>
            </div>
        </div>
    </div>
</div>