@model PracticeFlow.Models.Appointment
@{
    ViewData["Title"] = "Book Appointment";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Book New Appointment</h2>
        <a asp-controller="Home" asp-action="PatientDashboard" class="btn btn-secondary">Back to Dashboard</a>
    </div>
    <hr />

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger">
            @ViewBag.ErrorMessage
        </div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <strong>Please fix the following errors:</strong>
            <ul>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form asp-action="Book" method="post">
        <div class="form-group mb-3">
            <label>Select Doctor *</label>
            <select name="DoctorId" class="form-control" required>
                <option value="">-- Select Doctor --</option>
                @foreach (var doctor in ViewBag.Doctors)
                {
                    <option value="@doctor.UserID" selected="@(ViewBag.SelectedDoctorId == doctor.UserID ? "selected" : null)">@doctor.FullName</option>
                }
            </select>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label>Appointment Date *</label>
                    <input type="date" name="AppointmentDate" class="form-control" 
                           min="@DateTime.Now.ToString("yyyy-MM-dd")" 
                           value="@(ViewBag.SelectedDate ?? DateTime.Now.ToString("yyyy-MM-dd"))" required />
                    <small class="text-muted">Please select a future date</small>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label>Appointment Time *</label>
                    <select name="AppointmentTime" class="form-control" required>
                        <option value="">-- Select Time --</option>
                        <option value="09:00" selected="@(ViewBag.SelectedTime == "09:00" ? "selected" : null)">9:00 AM</option>
                        <option value="09:30" selected="@(ViewBag.SelectedTime == "09:30" ? "selected" : null)">9:30 AM</option>
                        <option value="10:00" selected="@(ViewBag.SelectedTime == "10:00" ? "selected" : null)">10:00 AM</option>
                        <option value="10:30" selected="@(ViewBag.SelectedTime == "10:30" ? "selected" : null)">10:30 AM</option>
                        <option value="11:00" selected="@(ViewBag.SelectedTime == "11:00" ? "selected" : null)">11:00 AM</option>
                        <option value="11:30" selected="@(ViewBag.SelectedTime == "11:30" ? "selected" : null)">11:30 AM</option>
                        <option value="12:00" selected="@(ViewBag.SelectedTime == "12:00" ? "selected" : null)">12:00 PM</option>
                        <option value="12:30" selected="@(ViewBag.SelectedTime == "12:30" ? "selected" : null)">12:30 PM</option>
                        <option value="13:00" selected="@(ViewBag.SelectedTime == "13:00" ? "selected" : null)">1:00 PM</option>
                        <option value="13:30" selected="@(ViewBag.SelectedTime == "13:30" ? "selected" : null)">1:30 PM</option>
                        <option value="14:00" selected="@(ViewBag.SelectedTime == "14:00" ? "selected" : null)">2:00 PM</option>
                        <option value="14:30" selected="@(ViewBag.SelectedTime == "14:30" ? "selected" : null)">2:30 PM</option>
                        <option value="15:00" selected="@(ViewBag.SelectedTime == "15:00" ? "selected" : null)">3:00 PM</option>
                        <option value="15:30" selected="@(ViewBag.SelectedTime == "15:30" ? "selected" : null)">3:30 PM</option>
                        <option value="16:00" selected="@(ViewBag.SelectedTime == "16:00" ? "selected" : null)">4:00 PM</option>
                        <option value="16:30" selected="@(ViewBag.SelectedTime == "16:30" ? "selected" : null)">4:30 PM</option>
                        <option value="17:00" selected="@(ViewBag.SelectedTime == "17:00" ? "selected" : null)">5:00 PM</option>
                    </select>
                    <small class="text-muted">Doctor hours: 9:00 AM - 5:00 PM</small>
                </div>
            </div>
        </div>

        <div class="form-group mb-3">
            <label>Reason for Visit *</label>
            <textarea name="Reason" class="form-control" rows="3" placeholder="Describe your symptoms or reason for visit" required>@ViewBag.EnteredReason</textarea>
        </div>

        <div class="form-group">
            <button type="submit" class="btn" style="background-color: #667eea; border-color: #667eea; color: white;">
                Book Appointment
            </button>
            <a asp-action="MyAppointments" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>