@model IEnumerable<PracticeFlow.Models.Appointment>

@{
    ViewData["Title"] = "My Appointment Schedule";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>My Appointment Schedule</h2>
    <div>
        <a asp-controller="DoctorMedicalRecord" asp-action="ViewRecords" class="btn" style="background-color: #06b6d4; border-color: #06b6d4; color: white;">
            Medical Records
        </a>
        <a asp-controller="Home" asp-action="DoctorDashboard" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Date & Time</th>
            <th>Patient</th>
            <th>Reason</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var appointment in Model)
        {
            <tr>
                <td>
                    <strong>@appointment.AppointmentDate.ToString("MMM dd, yyyy")</strong><br />
                    <small class="text-muted">@appointment.AppointmentDate.ToString("hh:mm tt")</small>
                </td>
                <td>
                    <strong>@appointment.Patient!.FullName</strong><br />
                    <small class="text-muted">@appointment.Patient.Email</small>
                </td>
                <td>@appointment.Reason</td>
                <td>
                    @if (appointment.Status == "Completed")
                    {
                        <span class="badge bg-success">Completed</span>
                    }
                    else if (appointment.Status == "Cancelled")
                    {
                        <span class="badge bg-danger">Cancelled</span>
                    }
                    else if (appointment.Status == "Past Due")
                    {
                        <span class="badge bg-warning text-dark">Past Due</span>
                    }
                    else
                    {
                        <span class="badge bg-primary">Scheduled</span>
                    }
                </td>
                <td>
                    @if (appointment.Status == "Completed")
                    {
                        @if (ViewBag.AppointmentRecordMap != null && ViewBag.AppointmentRecordMap.ContainsKey(appointment.AppointmentId))
                        {
                            <a asp-controller="DoctorMedicalRecord" 
                               asp-action="ViewDetails" 
                               asp-route-id="@ViewBag.AppointmentRecordMap[appointment.AppointmentId]" 
                               class="btn btn-sm" style="background-color: #06b6d4; border-color: #06b6d4; color: white;">
                                View Record
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">No record found</span>
                        }
                    }
                    else if (appointment.Status == "Past Due")
                    {
                        <a asp-controller="Appointment" 
                           asp-action="RecordVisit" 
                           asp-route-id="@appointment.AppointmentId" 
                           class="btn btn-sm btn-success">
                            Record Visit
                        </a>
                        <a asp-controller="Appointment" 
                           asp-action="CancelAppointment" 
                           asp-route-id="@appointment.AppointmentId" 
                           class="btn btn-sm btn-danger">
                            Cancel
                        </a>
                    }
                    else if (appointment.Status == "Scheduled")
                    {
                        <a asp-controller="Appointment" 
                           asp-action="RecordVisit" 
                           asp-route-id="@appointment.AppointmentId" 
                           class="btn btn-sm btn-success">
                            Record Visit
                        </a>
                        <a asp-controller="Appointment" 
                           asp-action="CancelAppointment" 
                           asp-route-id="@appointment.AppointmentId" 
                           class="btn btn-sm btn-danger">
                            Cancel
                        </a>
                    }
                    else if (appointment.Status == "Cancelled")
                    {
                        <span class="text-muted">-</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>