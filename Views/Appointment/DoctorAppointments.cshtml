@model IEnumerable<PracticeFlow.Models.Appointment>

@{
    ViewData["Title"] = "My Appointments - Doctor";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>My Appointment Schedule</h2>
        <div>
            <a asp-controller="DoctorMedicalRecord" asp-action="ViewRecords" class="btn btn-primary">Medical Records</a>
            <a asp-controller="Home" asp-action="DoctorDashboard" class="btn btn-secondary">Back to Dashboard</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            You don't have any appointments scheduled yet.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Date & Time</th>
                        <th>Patient</th>
                        <th>Reason</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var appointment in Model)
                    {
                        <tr>
                            <td>
                                <strong>@appointment.AppointmentDate.ToString("MMM dd, yyyy")</strong><br/>
                                <small class="text-muted">@appointment.AppointmentDate.ToString("hh:mm tt")</small>
                            </td>
                            <td>
                                <strong>@appointment.Patient?.FullName</strong><br/>
                                <small class="text-muted">@appointment.Patient?.Email</small>
                            </td>
                            <td>@appointment.Reason</td>
                            <td>
                                @{
                                    var today = DateTime.Today;
                                    var appointmentDate = appointment.AppointmentDate.Date;
                                    
                                    string statusText;
                                    string badgeColor;
                                    
                                    
                                    if (appointment.Status == "Cancelled")
                                    {
                                        statusText = "Cancelled";
                                        badgeColor = "danger";
                                    }
                                    else if (appointment.Status == "Completed")
                                    {
                                        statusText = "Completed";
                                        badgeColor = "secondary";
                                    }
                                    else if (appointmentDate == today)
                                    {
                                        statusText = "Today";
                                        badgeColor = "warning";
                                    }
                                    else if (appointmentDate < today)
                                    {
                                        statusText = "Past Due";
                                        badgeColor = "secondary";
                                    }
                                    else
                                    {
                                        statusText = "Scheduled";
                                        badgeColor = "primary";
                                    }
                                }
                                <span class="badge bg-@badgeColor">@statusText</span>
                            </td>
                            <td>
                                @if (appointment.Status == "Scheduled")
                                {
                                    <a asp-action="RecordVisit" asp-route-id="@appointment.AppointmentId" class="btn btn-sm btn-success">Record Visit</a>
                                    <a asp-action="CancelAppointment" asp-route-id="@appointment.AppointmentId" class="btn btn-sm btn-danger" 
                                       onclick="return confirm('Cancel this appointment?');">Cancel</a>
                                }
                                else if (appointment.Status == "Completed")
                                {
                                    @if (ViewBag.AppointmentRecordMap != null && 
                                         ((Dictionary<int, int>)ViewBag.AppointmentRecordMap).ContainsKey(appointment.AppointmentId))
                                    {
                                        var recordId = ((Dictionary<int, int>)ViewBag.AppointmentRecordMap)[appointment.AppointmentId];
                                        <a asp-controller="DoctorMedicalRecord" asp-action="ViewDetails" asp-route-id="@recordId" class="btn btn-sm btn-info">View Record</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">No record found</span>
                                    }
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <div class="mt-3">
            <p class="text-muted">Total Appointments: @Model.Count()</p>
        </div>
    }
</div>