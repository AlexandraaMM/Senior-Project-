@model IEnumerable<PracticeFlow.Models.Appointment>

@{
    ViewData["Title"] = "My Appointments";
}

<h2>My Appointments</h2>

<div class="mb-4">
    <a href="/Appointment/Book" class="btn btn-success me-2">Book New Appointment</a>
    <a asp-controller="Home" asp-action="PatientDashboard" class="btn btn-secondary">Back to Dashboard</a>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Doctor</th>
            <th>Date & Time</th>
            <th>Reason</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var appointment in Model)
        {
            <tr>
                <td>@(appointment.Doctor?.FullName ?? "N/A")</td>
                <td>@appointment.AppointmentDate.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@appointment.Reason</td>
                <td>@appointment.Status</td>
            </tr>
        }
    </tbody>
</table>