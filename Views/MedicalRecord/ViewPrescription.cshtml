@model PracticeFlow.Models.MedicalRecord

@{
    ViewData["Title"] = "Prescription Details";
}

<div class="container mt-4">
    <h2>Prescription Details</h2>
    <p class="text-muted">Medical Record from @Model.RecordDate.ToString("MMMM dd, yyyy")</p>
    <hr />

    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5>Visit Information</h5>
        </div>
        <div class="card-body">
            <p><strong>Doctor:</strong> @Model.Doctor?.FullName</p>
            <p><strong>Date:</strong> @Model.RecordDate.ToString("MMMM dd, yyyy")</p>
            <p><strong>Diagnosis:</strong> @Model.Diagnosis</p>
            <p><strong>Treatment:</strong> @Model.Treatment</p>
        </div>
    </div>

    @if (Model.Prescriptions != null && Model.Prescriptions.Any())
    {
        <div class="card">
            <div class="card-header bg-success text-white">
                <h5>Prescriptions</h5>
            </div>
            <div class="card-body">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Medication</th>
                            <th>Dosage</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Instructions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var prescription in Model.Prescriptions)
                        {
                            <tr>
                                <td>@prescription.MedicationName</td>
                                <td>@prescription.Dosage</td>
                                <td>@prescription.StartDate.ToString("yyyy-MM-dd")</td>
                                <td>@(prescription.EndDate?.ToString("yyyy-MM-dd") ?? "Ongoing")</td>
                                <td>@prescription.Instructions</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <div class="mt-3">
        <a asp-action="MyRecords" class="btn btn-secondary">Back to My Records</a>
    </div>
</div>