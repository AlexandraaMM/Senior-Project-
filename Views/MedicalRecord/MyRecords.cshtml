@model IEnumerable<PracticeFlow.Models.MedicalRecord>

@{
    ViewData["Title"] = "My Medical Records";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>My Medical Records</h2>
    <a asp-controller="Home" asp-action="PatientDashboard" class="btn btn-secondary">Back to Dashboard</a>
</div>

@if (!Model.Any())
{
    <p>No medical records found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Doctor</th>
                <th>Diagnosis</th>
                <th>Treatment</th>
                <th>Prescription</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var record in Model)
            {
                <tr>
                    <td>@record.RecordDate.ToString("yyyy-MM-dd")</td>
                    <td>@(record.Doctor?.FullName ?? "N/A")</td>
                    <td>@record.Diagnosis</td>
                    <td>@record.Treatment</td>
                    <td>@record.Prescription</td>
                </tr>
            }
        </tbody>
    </table>
}