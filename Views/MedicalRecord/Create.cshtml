@model PracticeFlow.Models.MedicalRecord

@{
    ViewData["Title"] = "Create Medical Record";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2>Create Medical Record</h2>
    <hr />

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <strong>Please fix the following errors:</strong>
            <ul>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        
        @if (ViewBag.AppointmentId != null)
        {
            <input type="hidden" name="AppointmentId" value="@ViewBag.AppointmentId" />
        }
        
        <div class="form-group mb-3">
            <label>Select Patient *</label>
            @if (ViewBag.IsFromAppointment == true && ViewBag.PreSelectedPatient != null)
            {
                <!-- Read-only display when from appointment -->
                <input type="text" class="form-control" value="@ViewBag.PreSelectedPatient.FullName" readonly style="background-color: #e9ecef;">
                <input type="hidden" name="PatientId" value="@ViewBag.PreSelectedPatient.UserID">
            }
            else
            {
                <!-- Dropdown when creating record directly -->
                <select name="PatientId" class="form-control" required>
                    <option value="">-- Select Patient --</option>
                    @foreach (var patient in (ViewBag.Patients as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)!)
                    {
                        <option value="@patient.Value">@patient.Text</option>
                    }
                </select>
            }
        </div>

        <div class="form-group mb-3">
            <label>Reason for Visit *</label>
            <input name="ReasonForVisit" class="form-control" placeholder="E.g., Annual checkup" 
                   value="@ViewBag.PreFilledReason" required />
        </div>

        <div class="form-group mb-3">
            <label>Diagnosis</label>
            <textarea name="Diagnosis" class="form-control" rows="3"></textarea>
        </div>

        <div class="form-group mb-3">
            <label>Treatment</label>
            <textarea name="Treatment" class="form-control" rows="3"></textarea>
        </div>

        <div class="form-group mb-3">
            <label>Additional Notes</label>
            <textarea name="Notes" class="form-control" rows="3"></textarea>
        </div>

        <hr />
        <h4>Prescription (Optional)</h4>
        <p class="text-muted">Add a prescription for this visit if needed</p>

        <div class="card mb-3">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label>Medication Name</label>
                        <input type="text" name="Prescription.MedicationName" class="form-control" placeholder="e.g., Ibuprofen" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label>Dosage</label>
                        <input type="text" name="Prescription.Dosage" class="form-control" placeholder="e.g., 200mg" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label>Start Date</label>
                        <input type="date" name="Prescription.StartDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label>End Date (Optional)</label>
                        <input type="date" name="Prescription.EndDate" class="form-control" />
                    </div>
                </div>
                <div class="mb-3">
                    <label>Instructions</label>
                    <textarea name="Prescription.Instructions" class="form-control" rows="2" placeholder="e.g., Take twice daily with food"></textarea>
                </div>
            </div>
        </div>

        <div class="form-group">
            <button type="submit" class="btn btn-primary">Save Medical Record</button>
            <a asp-controller="Appointment" asp-action="DoctorAppointments" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>